<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:clipToPadding="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/page_margin_horizontal"
        android:paddingTop="@dimen/space_5"
        android:paddingBottom="@dimen/space_8">

        <!-- Header greeting -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textSize="@dimen/text_xl"
            android:textColor="@color/foreground"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.02" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_description"
            android:textSize="@dimen/text_sm"
            android:textColor="@color/muted_foreground"
            android:layout_marginTop="2dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/powered_by"
            android:textSize="@dimen/text_xs"
            android:textColor="@color/muted_foreground"
            android:layout_marginTop="1dp" />

        <!-- ─── Balance Card ─────────────────────────────────────── -->

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardBalance"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_5"
            app:cardCornerRadius="@dimen/radius_lg"
            app:cardElevation="@dimen/elevation_none"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:cardBackgroundColor="@color/primary">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/space_5">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/tap_to_check_balance"
                    android:textSize="@dimen/text_sm"
                    android:textColor="#B3FFFFFF"
                    android:letterSpacing="0.04" />

                <TextView
                    android:id="@+id/balanceAmount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="——"
                    android:textSize="@dimen/text_4xl"
                    android:textColor="@color/white"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginTop="@dimen/space_1" />

                <TextView
                    android:id="@+id/balanceLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/checking_balance"
                    android:textSize="@dimen/text_sm"
                    android:textColor="#B3FFFFFF"
                    android:layout_marginTop="@dimen/space_1" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- ─── Quick Actions Grid ────────────────────────────────── -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Send Money"
            android:textSize="@dimen/text_lg"
            android:textColor="@color/foreground"
            android:fontFamily="sans-serif-medium"
            android:layout_marginTop="@dimen/space_6"
            android:layout_marginBottom="@dimen/space_3" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2">

            <!-- Scan QR -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnScanQR"
                android:layout_width="0dp"
                android:layout_height="@dimen/action_card_height"
                android:layout_weight="1"
                android:layout_marginEnd="@dimen/space_2"
                app:cardCornerRadius="@dimen/radius_lg"
                app:cardElevation="@dimen/elevation_none"
                app:strokeWidth="1dp"
                app:strokeColor="@color/border"
                app:cardBackgroundColor="@color/card"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="@dimen/icon_lg"
                        android:layout_height="@dimen/icon_lg"
                        android:src="@drawable/ic_qr"
                        android:importantForAccessibility="no"
                        app:tint="@color/primary" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/scan_qr"
                        android:textSize="@dimen/text_sm"
                        android:textColor="@color/foreground"
                        android:layout_marginTop="@dimen/space_2"
                        android:fontFamily="sans-serif-medium" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Send to Mobile -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnSendMobile"
                android:layout_width="0dp"
                android:layout_height="@dimen/action_card_height"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/space_2"
                app:cardCornerRadius="@dimen/radius_lg"
                app:cardElevation="@dimen/elevation_none"
                app:strokeWidth="1dp"
                app:strokeColor="@color/border"
                app:cardBackgroundColor="@color/card"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="@dimen/icon_lg"
                        android:layout_height="@dimen/icon_lg"
                        android:src="@drawable/ic_send_mobile"
                        android:importantForAccessibility="no"
                        app:tint="@color/success" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/send_to_mobile"
                        android:textSize="@dimen/text_sm"
                        android:textColor="@color/foreground"
                        android:layout_marginTop="@dimen/space_2"
                        android:fontFamily="sans-serif-medium" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2"
            android:layout_marginTop="@dimen/space_3">

            <!-- Send to Bank -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnSendBank"
                android:layout_width="0dp"
                android:layout_height="@dimen/action_card_height"
                android:layout_weight="1"
                android:layout_marginEnd="@dimen/space_2"
                app:cardCornerRadius="@dimen/radius_lg"
                app:cardElevation="@dimen/elevation_none"
                app:strokeWidth="1dp"
                app:strokeColor="@color/border"
                app:cardBackgroundColor="@color/card"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="@dimen/icon_lg"
                        android:layout_height="@dimen/icon_lg"
                        android:src="@drawable/ic_bank"
                        android:importantForAccessibility="no"
                        app:tint="#F59E0B" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/send_to_bank"
                        android:textSize="@dimen/text_sm"
                        android:textColor="@color/foreground"
                        android:layout_marginTop="@dimen/space_2"
                        android:fontFamily="sans-serif-medium" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Check Balance -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardCheckBalance"
                android:layout_width="0dp"
                android:layout_height="@dimen/action_card_height"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/space_2"
                app:cardCornerRadius="@dimen/radius_lg"
                app:cardElevation="@dimen/elevation_none"
                app:strokeWidth="1dp"
                app:strokeColor="@color/border"
                app:cardBackgroundColor="@color/card"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="@dimen/icon_lg"
                        android:layout_height="@dimen/icon_lg"
                        android:src="@drawable/ic_wallet"
                        android:importantForAccessibility="no"
                        app:tint="#8B5CF6" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/check_balance"
                        android:textSize="@dimen/text_sm"
                        android:textColor="@color/foreground"
                        android:layout_marginTop="@dimen/space_2"
                        android:fontFamily="sans-serif-medium" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

        <!-- ─── Divider ────────────────────────────────────────────── -->

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/border"
            android:layout_marginVertical="@dimen/space_5" />

        <!-- ─── Other Services ─────────────────────────────────────── -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Other Services"
            android:textSize="@dimen/text_lg"
            android:textColor="@color/foreground"
            android:fontFamily="sans-serif-medium"
            android:layout_marginBottom="@dimen/space_3" />

        <!-- Mini Statement -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardMiniStatement"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="@dimen/radius_lg"
            app:cardElevation="@dimen/elevation_none"
            app:strokeWidth="1dp"
            app:strokeColor="@color/border"
            app:cardBackgroundColor="@color/card"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="@dimen/space_4">

                <ImageView
                    android:layout_width="@dimen/icon_xl"
                    android:layout_height="@dimen/icon_xl"
                    android:src="@drawable/ic_statement"
                    android:importantForAccessibility="no"
                    app:tint="@color/muted_foreground" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="@dimen/space_3">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/mini_statement"
                        android:textSize="@dimen/text_base"
                        android:textColor="@color/foreground"
                        android:fontFamily="sans-serif-medium" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Last 5 transactions"
                        android:textSize="@dimen/text_sm"
                        android:textColor="@color/muted_foreground"
                        android:layout_marginTop="1dp" />

                </LinearLayout>

                <ImageView
                    android:layout_width="@dimen/icon_md"
                    android:layout_height="@dimen/icon_md"
                    android:src="@drawable/ic_chevron_right"
                    android:importantForAccessibility="no"
                    app:tint="@color/muted_foreground" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ─── Recent Transactions ────────────────────────────────── -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/recent_activity"
            android:textSize="@dimen/text_lg"
            android:textColor="@color/foreground"
            android:fontFamily="sans-serif-medium"
            android:layout_marginTop="@dimen/space_6"
            android:layout_marginBottom="@dimen/space_3" />

        <TextView
            android:id="@+id/emptyRecent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/no_recent_transactions"
            android:textSize="@dimen/text_sm"
            android:textColor="@color/muted_foreground"
            android:gravity="center"
            android:paddingVertical="@dimen/space_8" />

        <LinearLayout
            android:id="@+id/recentContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>
