<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/page_margin_horizontal"
            android:paddingTop="@dimen/space_5"
            android:paddingBottom="@dimen/space_4">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/transactions"
                android:textSize="@dimen/text_xl"
                android:textColor="@color/foreground"
                android:fontFamily="sans-serif-medium" />

        </LinearLayout>

        <!-- Empty state (shown when no transactions) -->
        <LinearLayout
            android:id="@+id/emptyState"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="visible"
            android:paddingHorizontal="@dimen/space_8">

            <ImageView
                android:layout_width="@dimen/icon_xxl"
                android:layout_height="@dimen/icon_xxl"
                android:src="@drawable/ic_history"
                android:importantForAccessibility="no"
                app:tint="@color/muted_foreground"
                android:alpha="0.4" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/no_history_yet"
                android:textSize="@dimen/text_lg"
                android:textColor="@color/muted_foreground"
                android:layout_marginTop="@dimen/space_4"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/no_history_description"
                android:textSize="@dimen/text_sm"
                android:textColor="@color/muted_foreground"
                android:layout_marginTop="@dimen/space_1" />

        </LinearLayout>

        <!-- Transaction list -->
        <ListView
            android:id="@+id/historyListView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"
            android:clipToPadding="false"
            android:paddingHorizontal="@dimen/page_margin_horizontal"
            android:paddingBottom="@dimen/space_8"
            android:divider="@android:color/transparent"
            android:dividerHeight="@dimen/space_2" />

    </LinearLayout>

</FrameLayout>
